{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@pulseboard/ui/*": ["../../ui/src/*"],
      "@pulseboard/db/*": ["../../db/src/*"],
      "@pulseboard/types/*": ["../../types/src/*"],
      "@pulseboard/cache/*": ["../../cache/src/*"],
      "@pulseboard/queue/*": ["../../queue/src/*"],
      "@pulseboard/email/*": ["../../email/src/*"],
      "@pulseboard/plugin-runtime/*": ["../../plugin-runtime/src/*"],
      "@pulseboard/plausible-sdk/*": ["../../plausible-sdk/src/*"],
      "@pulseboard/ai-engine/*": ["../../ai-engine/src/*"]
    },
    "jsx": "preserve"
  }
}

